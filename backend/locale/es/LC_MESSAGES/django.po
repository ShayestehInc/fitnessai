# Auth errors
msgid "Invalid credentials."
msgstr "Credenciales inválidas."

msgid "Account is disabled."
msgstr "La cuenta está deshabilitada."

msgid "Email is required."
msgstr "El correo electrónico es obligatorio."

msgid "Password is required."
msgstr "La contraseña es obligatoria."

# Validation
msgid "This field is required."
msgstr "Este campo es obligatorio."

msgid "Invalid email address."
msgstr "Dirección de correo electrónico inválida."

msgid "Password must be at least 8 characters."
msgstr "La contraseña debe tener al menos 8 caracteres."

msgid "Passwords do not match."
msgstr "Las contraseñas no coinciden."

# Trainer
msgid "Trainee not found."
msgstr "Alumno no encontrado."

msgid "Invitation sent successfully."
msgstr "Invitación enviada exitosamente."

msgid "Invitation has expired."
msgstr "La invitación ha expirado."

msgid "Program assigned successfully."
msgstr "Programa asignado exitosamente."

# Permissions
msgid "You do not have permission to perform this action."
msgstr "No tienes permiso para realizar esta acción."

msgid "Authentication credentials were not provided."
msgstr "No se proporcionaron credenciales de autenticación."

msgid "Token has expired."
msgstr "El token ha expirado."

# Profile
msgid "Profile updated successfully."
msgstr "Perfil actualizado exitosamente."

msgid "Language changed successfully."
msgstr "Idioma cambiado exitosamente."

# General
msgid "Not found."
msgstr "No encontrado."

msgid "Server error. Please try again later."
msgstr "Error del servidor. Por favor intenta más tarde."
