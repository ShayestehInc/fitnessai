# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=fitnessai
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# AI Provider Configuration
# Supported: openai, anthropic, google (default: anthropic)
AI_PROVIDER=anthropic
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Builder-specific AI (uses Gemini Flash for speed — 2-5s vs 15-30s)
# Falls back to AI_PROVIDER if not set
AI_BUILDER_PROVIDER=google
AI_BUILDER_MODEL=gemini-2.0-flash

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here


# Firebase Cloud Messaging (push notifications)
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# SerpAPI (for exercise image search)
# SERPAPI_KEY=your-serpapi-key-here

# DigitalOcean Spaces (S3-compatible storage)
# DO_SPACES_KEY=your-spaces-access-key
# DO_SPACES_SECRET=your-spaces-secret-key
# DO_SPACES_BUCKET=fitnessai-bucket
# DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# DO_SPACES_REGION=sfo3
