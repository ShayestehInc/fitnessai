# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end

  # Add a script phase to the main Runner target that strips simulator-only
  # frameworks before code signing (fixes objective_c.framework upload rejection).
  main_project = installer.aggregate_targets.first.user_project
  runner_target = main_project.targets.find { |t| t.name == 'Runner' }
  if runner_target
    phase_name = 'Strip Simulator Frameworks'
    unless runner_target.shell_script_build_phases.any? { |p| p.name == phase_name }
      phase = runner_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = <<~SCRIPT
        # Remove simulator-only frameworks that Apple rejects on upload.
        find "${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}" -name '*.framework' -type d | while read -r fw; do
          binary="${fw}/$(basename "${fw}" .framework)"
          [ -f "$binary" ] || continue
          if otool -lv "$binary" 2>/dev/null | grep -A5 "LC_BUILD_VERSION" | grep -q "IOSSIMULATOR"; then
            echo "Removing simulator-only framework: $(basename "$fw")"
            rm -rf "$fw"
          fi
        done
      SCRIPT
      phase.input_paths = []
      phase.output_paths = []

      # Move it before the Embed Frameworks phase
      embed_index = runner_target.build_phases.index { |p| p.respond_to?(:name) && p.name&.include?('Embed') }
      if embed_index
        runner_target.build_phases.move(phase, embed_index)
      end
      main_project.save
    end
  end
end
