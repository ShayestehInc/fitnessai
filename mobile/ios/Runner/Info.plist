	<string>FitnessAI writes workout data to Apple Health so your activity rings stay up to date.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Select photos to use as exercise images.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.678085268098-oiujkrm9mavo40jtpgjq9vbu0ki25nl0</string>
			</array>
		</dict>
	</array>
